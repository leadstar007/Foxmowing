---
import { ASSETS } from "../data/site";
interface Props { eyebrow: string; title: string; intro: string; image?: string; imageAlt?: string; crumbs?: { label: string; href?: string }[]; }
const { eyebrow, title, intro, image = ASSETS.hedging, imageAlt = "Fox outdoor maintenance service", crumbs = [] } = Astro.props;
---
<section class="interior-hero">
  <img src={image} alt={imageAlt} width="1600" height="900" fetchpriority="high" />
  <div class="interior-scrim"></div>
  <div class="container interior-content">
    {crumbs.length > 0 && <nav class="breadcrumbs" aria-label="Breadcrumb">{crumbs.map((crumb, index) => <span>{index > 0 && <b aria-hidden="true">/</b>}{crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span aria-current="page">{crumb.label}</span>}</span>)}</nav>}
    <span class="eyebrow">{eyebrow}</span><h1>{title}</h1><p>{intro}</p>
  </div>
</section>

