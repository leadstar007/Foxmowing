---
import type { Service } from "../data/site";
interface Props { services: Service[]; }
const { services } = Astro.props;
---
<div class="service-card-grid">
  {services.map((service) => <article class="service-card"><div class="service-card-image"><img src={service.image} alt={service.imageAlt} width="700" height="700" loading="lazy" /></div><div class="service-card-copy"><span class="eyebrow dark">{service.eyebrow}</span><h2>{service.name}</h2><p>{service.summary}</p><a href={`/services/${service.slug}`}>View service <span aria-hidden="true">→</span></a></div></article>)}
</div>

