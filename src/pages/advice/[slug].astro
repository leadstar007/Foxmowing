---
import BaseLayout from "../../layouts/BaseLayout.astro"; import PageHero from "../../components/PageHero.astro"; import FinalCTA from "../../components/FinalCTA.astro"; import { ASSETS, adviceArticles } from "../../data/site";
export function getStaticPaths(){ return adviceArticles.map((article)=>({params:{slug:article.slug},props:{article}})); } const { article }=Astro.props;
const copy:Record<string,{sections:{h:string;p:string;points:string[]}[]}>= {
"planning-a-garden-clean-up":{sections:[{h:"Start with the outcome",p:"Decide whether the priority is access, presentation, overgrowth or preparation for recurring maintenance.",points:["List the areas that matter most","Photograph access constraints","Identify material that may need removal"]},{h:"Make scope easier to assess",p:"A useful brief notes approximate garden size, current condition, parking or gate access and any time constraints.",points:["Mention steep or restricted areas","Separate essential work from optional work","Ask how green waste will be handled"]}]},
"choosing-a-mowing-schedule":{sections:[{h:"Match the rhythm to the lawn",p:"Growth rate changes with season, rainfall, turf type, shade and irrigation. A useful schedule keeps presentation consistent without removing too much growth at once.",points:["Consider seasonal growth","Agree the expected finish","Review the schedule when conditions change"]},{h:"Include access and edges",p:"Gate widths, pets, parked vehicles and edging requirements can all influence service time and method.",points:["Confirm access before the visit","Point out irrigation or obstacles","Discuss clippings and tidy-up expectations"]}]},
"commercial-grounds-brief":{sections:[{h:"Describe the presentation standard",p:"Identify the visible areas, service frequencies and business requirements that matter to stakeholders.",points:["Map lawns, beds and common areas","Note operating-hour restrictions","Nominate the primary contact"]},{h:"Make the scope repeatable",p:"A clear task list and reporting pathway supports consistent quoting, service delivery and review.",points:["Separate routine and seasonal tasks","Document access and safety requirements","Agree how variations are approved"]}]}}
const content=copy[article.slug];
---
<BaseLayout title={article.title} description={article.excerpt} image={ASSETS.premiumLawn}><PageHero eyebrow={article.category} title={article.title} intro={article.excerpt} image={ASSETS.premiumLawn} imageAlt="Maintained lawn and garden" crumbs={[{label:"Home",href:"/"},{label:"Advice",href:"/advice"},{label:article.title}]}/><article class="section-pad"><div class="container narrow editorial-copy">{content.sections.map((section)=><section><h2>{section.h}</h2><p>{section.p}</p><ul>{section.points.map((point)=><li>{point}</li>)}</ul></section>)}<div class="editorial-note"><span class="eyebrow dark">Ready to ask Fox?</span><h2>Turn the plan into a useful quote request.</h2><a class="button button-dark" href="/free-quote">Get a free quote</a></div></div></article><FinalCTA/></BaseLayout>

