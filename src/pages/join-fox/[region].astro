---
import BaseLayout from "../../layouts/BaseLayout.astro"; import PageHero from "../../components/PageHero.astro"; import { ASSETS, regions } from "../../data/site";
export function getStaticPaths(){return regions.map((region)=>({params:{region:region.slug},props:{region}}));} const {region}=Astro.props;
---
<BaseLayout title={`Fox franchise opportunities in ${region.name}`} description={`Explore Fox Mowing & Gardening franchise and territory opportunities in ${region.name}.`}><PageHero eyebrow="Fox franchise territories" title={`Build with Fox in ${region.name}.`} intro="Explore the first steps toward a Fox mowing and gardening business in your preferred region." image={ASSETS.franchisees} imageAlt="Fox franchise operators beside branded equipment" crumbs={[{label:"Home",href:"/"},{label:"Join Fox",href:"/join-fox-team"},{label:region.name}]}/><section class="section-pad"><div class="container detail-grid"><div class="detail-copy"><h2>Start with your region and goals.</h2><p>Territory availability changes and must be confirmed directly. Use the dedicated enquiry form to share your location, timeframe and what you want to build.</p><div class="check-list light"><span>✓ Recognised Fox branding</span><span>✓ Training and business systems</span><span>✓ Ongoing network support</span><span>✓ Region-specific territory discussion</span></div></div><aside class="detail-aside"><div class="aside-card"><span class="eyebrow dark">{region.short} enquiry</span><h2>Ask about a territory.</h2><p>Your regional preference will be preselected in the secure franchise form.</p><a class="button button-dark" href={`/join-fox/enquiry?region=${region.slug}`}>Enquire now</a></div></aside></div></section></BaseLayout>

