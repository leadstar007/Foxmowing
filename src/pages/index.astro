---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import FAQList from "../components/FAQList.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { ASSETS, BRAND, faqs, heroSlides, regions, services } from "../data/site";
const schema = { "@context": "https://schema.org", "@type": "HomeAndConstructionBusiness", name: BRAND.name, url: "https://foxmowing.com.au", telephone: BRAND.phoneDisplay, email: BRAND.email, areaServed: ["Australia", "New Zealand"] };
---
<BaseLayout title={BRAND.name} description="Professional lawn mowing, gardening and property care from local Fox teams across Australia and New Zealand." image={heroSlides[0].image.desktop1600.webp} preloadImage={heroSlides[0].image.desktop1600.avif} structuredData={schema}>
  <HeroCarousel />
  <section class="audience-switcher section-black"><div class="container audience-grid">
    <div class="section-intro"><span class="eyebrow">Choose your path</span><h2>Outdoor care for properties of every scale.</h2></div>
    <a class="audience-card residential" href="/residential"><span>Homes &amp; gardens</span><h3>Residential care</h3><p>One-off or recurring lawn, garden and property work tailored to the site.</p><b>Explore residential <span aria-hidden="true">→</span></b></a>
    <a class="audience-card commercial" href="/commercial"><span>Businesses &amp; strata</span><h3>Commercial grounds</h3><p>Planned grounds maintenance for presentation, access and operational needs.</p><b>Explore commercial <span aria-hidden="true">→</span></b></a>
  </div></section>
  <section class="section-pad"><div class="container"><div class="section-head split"><div><span class="eyebrow dark">Fox services</span><h2>A practical answer for the work outside.</h2></div><p>Browse common services, then use the quote form so a local Fox team can assess the property, scope and availability.</p></div><div class="service-ticker">{services.slice(0,9).map((service,index)=><a href={`/services/${service.slug}`}><span>{String(index+1).padStart(2,"0")}</span><b>{service.name}</b><span aria-hidden="true">→</span></a>)}</div></div></section>
  <section class="section-pad section-soft"><div class="container"><div class="section-head"><span class="eyebrow dark">Property solutions</span><h2>Focused care, from the front lawn to the shared grounds.</h2></div><div class="feature-grid">
    <article class="feature-card feature-1"><img src={ASSETS.hedging} alt="Fox operator trimming a mature hedge" width="900" height="1100" loading="lazy"/><div class="feature-overlay"></div><div class="feature-copy"><span>Residential</span><h3>Lawns and gardens, consistently presented.</h3><p>Plan routine upkeep or a focused clean-up with your local operator.</p><a href="/residential">Residential services →</a></div></article>
    <article class="feature-card"><img src={ASSETS.commercial} alt="Maintained grounds at a commercial property" width="900" height="600" loading="lazy"/><div class="feature-overlay"></div><div class="feature-copy"><span>Commercial</span><h3>Grounds ready for business.</h3><a href="/commercial">Commercial services →</a></div></article>
    <article class="feature-card"><img src={ASSETS.acreage} alt="Large acreage lawn being maintained" width="900" height="600" loading="lazy"/><div class="feature-overlay"></div><div class="feature-copy"><span>Larger properties</span><h3>More ground, properly assessed.</h3><a href="/services/acreage-mowing">Acreage mowing →</a></div></article>
  </div></div></section>
  <section class="section-pad section-black"><div class="container why-grid"><div class="why-image"><img src={ASSETS.franchisees} alt="Fox franchise operators together" width="900" height="900" loading="lazy"/><div class="lime-stamp"><b>LOCAL<br/>FOX TEAM</b></div></div><div class="why-copy"><span class="eyebrow">Why Fox</span><h2>Local ownership backed by a recognised network.</h2><p>Fox connects customers with local operators while providing a clear national gateway, established business systems and regional support.</p><div class="check-list"><span>✓ Local follow-up</span><span>✓ Clear scope first</span><span>✓ Residential and commercial</span><span>✓ AU and NZ network</span></div><a class="button button-primary" href="/about">About the Fox network</a></div></div></section>
  <section class="commercial-band"><img src={ASSETS.commercial} alt="Professionally managed commercial grounds" width="1600" height="900" loading="lazy"/><div class="commercial-scrim"></div><div class="container commercial-copy"><span class="eyebrow">Commercial grounds</span><h2>A maintenance scope built around the property.</h2><p>Share site priorities, access constraints and preferred service frequency so the local team can assess the work properly.</p><a class="button button-primary" href="/free-quote?audience=commercial">Request a commercial quote</a></div></section>
  <section class="section-pad"><div class="container location-grid"><div><span class="eyebrow dark">Find your region</span><h2>Local Fox websites across Australia and New Zealand.</h2><p>Choose your state, territory or New Zealand gateway for local service information and regional contact details.</p><a class="button button-dark" href="/locations">View all locations</a></div><div class="region-stack">{regions.map((region)=><a href={`/locations/${region.slug}`}><span>{region.short}</span><b>{region.name}</b><span aria-hidden="true">↗</span></a>)}</div></div></section>
  <section class="franchise-banner section-lime"><div class="container franchise-grid"><div><span class="eyebrow dark">Join Fox</span><h2>Own the work. Build the business.</h2><p>Explore a recognised brand, established systems, training and ongoing support.</p><a class="button button-dark" href="/join-fox-team">Explore Fox franchises</a></div><img src={ASSETS.franchisees} alt="Fox franchise team" width="1000" height="750" loading="lazy"/></div></section>
  <section class="section-pad section-soft"><div class="container faq-grid"><div><span class="eyebrow dark">Common questions</span><h2>Know the next step.</h2><p>Availability and pricing are confirmed locally after the service and property details are reviewed.</p><a class="text-link dark-link" href="/faq">View all FAQs →</a></div><FAQList items={faqs.slice(0,4)} /></div></section>
  <FinalCTA />
</BaseLayout>

