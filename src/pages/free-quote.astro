---
import BaseLayout from "../layouts/BaseLayout.astro"; import EnquiryForm from "../components/EnquiryForm.astro"; import { ASSETS, BRAND } from "../data/site";
---
<BaseLayout title="Get a free Fox quote" description="Request a residential, commercial or general Fox Mowing & Gardening service quote."><section class="form-hero section-black"><div class="container form-layout"><div class="form-intro"><span class="eyebrow">Customer enquiries</span><h1>Tell us what needs doing.</h1><p>Share the service, property and contact details a local Fox team needs to assess your request. A submission does not confirm a booking or fixed price.</p><div class="form-points"><span>✓ Residential, commercial or general</span><span>✓ Server-side validation and secure storage</span><span>✓ Local scope and availability confirmed later</span></div><a class="text-link" href={BRAND.phoneHref}>Prefer to call? {BRAND.phoneDisplay}</a></div><EnquiryForm kind="customer" /></div></section><section class="section-pad section-soft"><div class="container narrow"><h2>Before you submit</h2><p>Include access constraints, approximate size, current condition and the result you want. Personal information is handled in line with the privacy policy.</p><img class="form-support-image" src={ASSETS.beautifulLawn} alt="Well-maintained residential lawn" width="1200" height="600" loading="lazy"/></div></section></BaseLayout>

