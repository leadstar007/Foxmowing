---
import BaseLayout from "../../layouts/BaseLayout.astro"; import PageHero from "../../components/PageHero.astro"; import FinalCTA from "../../components/FinalCTA.astro"; import { ASSETS, regions } from "../../data/site";
export function getStaticPaths(){ return regions.map((region)=>({params:{region:region.slug},props:{region}})); } const { region }=Astro.props;
---
<BaseLayout title={`Fox Mowing & Gardening ${region.name}`} description={`Continue to the official Fox ${region.name} website for local lawn mowing, gardening and contact information.`}><PageHero eyebrow={`${region.short} regional gateway`} title={`Fox in ${region.name}.`} intro="You are on the national Fox website. Continue to the official regional website for local services, availability and contact details." image={region.slug==="new-zealand"?ASSETS.beautifulLawn:ASSETS.acreage} imageAlt={`Maintained outdoor property representing Fox ${region.name}`} crumbs={[{label:"Home",href:"/"},{label:"Locations",href:"/locations"},{label:region.name}]}/><section class="section-pad"><div class="container narrow gateway-card"><span class="eyebrow dark">Official regional website</span><h2>Continue to Fox {region.name}</h2><p>The regional website opens in the same tab. Its local service details, privacy information and contact pathways apply once you continue.</p><a class="button button-dark" href={region.url} rel="external">Visit Fox {region.short} <span aria-hidden="true">↗</span></a></div></section><FinalCTA/></BaseLayout>

