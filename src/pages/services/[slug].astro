---
import BaseLayout from "../../layouts/BaseLayout.astro"; import PageHero from "../../components/PageHero.astro"; import FinalCTA from "../../components/FinalCTA.astro"; import ServiceCards from "../../components/ServiceCards.astro"; import { services } from "../../data/site";
export function getStaticPaths(){ return services.map((service)=>({params:{slug:service.slug},props:{service}})); }
const { service } = Astro.props; const related = services.filter((item)=>item.slug!==service.slug && item.audiences.some((audience)=>service.audiences.includes(audience))).slice(0,2);
const schema={"@context":"https://schema.org","@type":"Service",name:service.name,description:service.description,provider:{"@type":"Organization",name:"Fox Mowing & Gardening"},areaServed:["Australia","New Zealand"]};
---
<BaseLayout title={service.name} description={service.description} image={service.image} structuredData={schema}><PageHero eyebrow={service.eyebrow} title={service.name} intro={service.summary} image={service.image} imageAlt={service.imageAlt} crumbs={[{label:"Home",href:"/"},{label:"Services",href:"/services"},{label:service.name}]}/><section class="section-pad"><div class="container detail-grid"><article class="detail-copy"><span class="eyebrow dark">Service overview</span><h2>Start with the property, scope and access.</h2><p>{service.description}</p><h2>What to discuss when requesting a quote</h2><div class="check-list light">{service.benefits.map((benefit)=><span>✓ {benefit}</span>)}<span>✓ Property location and access</span><span>✓ Preferred timing or frequency</span></div><p>Final availability, method and pricing are confirmed by the local Fox operator or regional team after the enquiry is reviewed.</p></article><aside class="detail-aside"><div class="aside-card"><span class="eyebrow dark">Request a quote</span><h2>Tell Fox about the work.</h2><p>Choose this service in the customer form and include any useful access or property notes.</p><a class="button button-dark" href={`/free-quote?service=${service.slug}`}>Get a free quote</a></div></aside></div></section><section class="section-pad section-soft"><div class="container"><div class="section-head"><span class="eyebrow dark">Related services</span><h2>More ways to care for the property.</h2></div><ServiceCards services={related}/></div></section><FinalCTA/></BaseLayout>

