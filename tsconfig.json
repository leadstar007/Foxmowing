{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*", "tests/**/*", "astro.config.mjs"],
  "exclude": ["dist", "client", "server", "drizzle", "drizzle.config.ts", "vite.config.ts", "node_modules"],
  "compilerOptions": {
